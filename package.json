{
  "name": "ziwei-mingpan",
  "version": "1.0.0",
  "description": "紫微斗数命盘",
  "main": "electron/main.js",
  "author": "ziwei",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder --mac --win portable",
    "sync:www": "node scripts/sync-www.js",
    "android:sync": "npm run sync:www && npx cap sync android",
    "android:build": "bash scripts/build-android.sh",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ziwei.mingpan",
    "productName": "紫微命盘",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "ziwei-mingpan.html",
      "manifest.json",
      "sw.js",
      "assets/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "icon": "assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "portable"
      ]
    },
    "dmg": {
      "title": "紫微命盘"
    }
  }
}
